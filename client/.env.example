# Backend Configuration
EXPO_PUBLIC_BACKEND_TYPE=local

# API server base URL
# iOS simulator: localhost resolves to the host machine
# Physical device: replace with your machine's LAN IP, e.g. http://192.168.1.x:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Google OAuth — web client ID (must match GOOGLE_CLIENT_ID in server/.env)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# iOS OAuth client ID (create in Google Console → iOS type, bundle ID: com.hip26.digitalbalanceathome)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=844457982348-uqtk28ofbuniet69o5bggv80738fgts1.apps.googleusercontent.com
